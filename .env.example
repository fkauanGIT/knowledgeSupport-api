# Se apontar para o pooler do Supabase (porta 6543, modo "Transaction"/PgBouncer),
# adicione "?prepareThreshold=0" no final — sem isso o driver usa prepared statements
# no servidor, que quebram nesse modo de pool com erros como "prepared statement already exists".
DB_URL=jdbc:postgresql://localhost:5432/demo
DB_USERNAME=demo
DB_PASSWORD=demo

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=put-your-token-here
JIRA_JQL=ORDER BY created DESC

API_KEY=replace-with-a-strong-secret-key